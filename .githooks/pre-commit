#!/usr/bin/env sh

set -eu

echo "[pre-commit] Running Bandit security scan..."
python -m bandit -q -r src/ai_container_intelligence

echo "[pre-commit] Scanning staged files for secret-like patterns..."
STAGED_FILES="$(git diff --cached --name-only --diff-filter=ACM)"

if [ -n "$STAGED_FILES" ]; then
  FOUND_SECRETS=0
  IFS='
'
  for FILE in $STAGED_FILES; do
    [ -f "$FILE" ] || continue
    if grep -n -E "BEGIN (RSA|EC|OPENSSH|PRIVATE) KEY|AKIA[0-9A-Z]{16}|xox[baprs]-|ghp_[A-Za-z0-9]{36}" -- "$FILE" >/dev/null 2>&1; then
      echo "Potential secret-like material detected in staged files. File: $FILE" >&2
      FOUND_SECRETS=1
    fi
  done
  unset IFS

  if [ "$FOUND_SECRETS" -ne 0 ]; then
    exit 1
  fi
fi

echo "[pre-commit] Security checks passed."
